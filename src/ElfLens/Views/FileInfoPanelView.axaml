<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ElfLens.Core.ViewModels"
             x:Class="ElfLens.Views.FileInfoPanelView"
             x:DataType="vm:FileInfoPanelViewModel">

    <Grid RowDefinitions="Auto,*,Auto" Margin="4">
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="8,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
        </StackPanel>

        <!-- Output -->
        <TextBox Grid.Row="1"
                 Text="{Binding OutputText}"
                 IsReadOnly="True"
                 FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                 FontSize="12"
                 Foreground="#E0E0E0"
                 Background="Transparent"
                 BorderThickness="0"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 CaretBrush="Transparent" />
    </Grid>
</UserControl>
