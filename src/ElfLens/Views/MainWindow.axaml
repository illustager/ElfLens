<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ElfLens.Core.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="ElfLens.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ElfLens">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TabItem" x:DataType="vm:PanelViewModel">
            <Setter Property="Header" Value="{Binding Title}" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*">

        <!-- Status Bar -->
        <Border Grid.Row="0" Padding="12,6"
                Background="{DynamicResource SystemAltHighBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="10" Height="10" Fill="#4CAF50"
                         IsVisible="{Binding IsConnected}" />
                <Ellipse Width="10" Height="10" Fill="#F44336"
                         IsVisible="{Binding IsConnected, Converter={x:Static BoolConverters.Not}}" />
                <TextBlock Text="{Binding ConnectionStatus}"
                           FontSize="12" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Connect Page -->
        <ScrollViewer Grid.Row="1"
                      IsVisible="{Binding IsConnected, Converter={x:Static BoolConverters.Not}}">
            <ContentControl Content="{Binding ConnectPage}" />
        </ScrollViewer>

        <!-- Workspace -->
        <Grid Grid.Row="1"
              IsVisible="{Binding IsConnected}"
              ColumnDefinitions="220,4,*,4,220"
              RowDefinitions="*,4,200">

            <!-- Left panels -->
            <TabControl Grid.Column="0" Grid.Row="0"
                        ItemsSource="{Binding LeftPanels}"
                        Background="{DynamicResource SystemAltMediumLowBrush}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PanelViewModel">
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>

            <GridSplitter Grid.Column="1" Grid.Row="0" Width="5"
                          Background="Transparent" HorizontalAlignment="Stretch" />
            <Border Grid.Column="1" Grid.Row="0" Width="1"
                    Background="#2A2A2A" HorizontalAlignment="Stretch"
                    IsHitTestVisible="False" />

            <!-- Center panels -->
            <TabControl Grid.Column="2" Grid.Row="0"
                        ItemsSource="{Binding CenterPanels}"
                        Background="{DynamicResource SystemAltHighBrush}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PanelViewModel">
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>

            <GridSplitter Grid.Column="3" Grid.Row="0" Width="5"
                          Background="Transparent" HorizontalAlignment="Stretch" />
            <Border Grid.Column="3" Grid.Row="0" Width="1"
                    Background="#2A2A2A" HorizontalAlignment="Stretch"
                    IsHitTestVisible="False" />

            <!-- Right panels -->
            <TabControl Grid.Column="4" Grid.Row="0"
                        ItemsSource="{Binding RightPanels}"
                        Background="{DynamicResource SystemAltMediumLowBrush}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PanelViewModel">
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>

            <!-- Horizontal splitter -->
            <GridSplitter Grid.Column="0" Grid.ColumnSpan="5"
                          Grid.Row="1" Height="5"
                          Background="Transparent" HorizontalAlignment="Stretch" />
            <Border Grid.Column="0" Grid.ColumnSpan="5"
                    Grid.Row="1" Height="1"
                    Background="#2A2A2A" HorizontalAlignment="Stretch"
                    IsHitTestVisible="False" />

            <!-- Bottom panels -->
            <TabControl Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="2"
                        ItemsSource="{Binding BottomPanels}"
                        SelectedItem="{Binding SelectedBottomPanel}"
                        Background="{DynamicResource SystemAltMediumLowBrush}">
                <TabControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:PanelViewModel">
                        <ContentControl Content="{Binding}" />
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>

        </Grid>

    </Grid>
</Window>
