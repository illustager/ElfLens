<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ElfLens.Core.ViewModels"
             xmlns:ae="using:AvaloniaEdit"
             x:Class="ElfLens.Views.DisassemblyPanelView"
             x:DataType="vm:DisassemblyPanelViewModel">

    <Grid RowDefinitions="Auto,*" Margin="4">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="8,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
            <TextBlock Text="{Binding FunctionCount}" FontSize="12"
                       VerticalAlignment="Center" Opacity="0.7" />
        </StackPanel>

        <ae:TextEditor Grid.Row="1" x:Name="Editor"
                       IsReadOnly="True"
                       ShowLineNumbers="True"
                       FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                       FontSize="12"
                       WordWrap="False"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto"
                       SyntaxHighlighting="x86 Assembly" />
    </Grid>
</UserControl>
