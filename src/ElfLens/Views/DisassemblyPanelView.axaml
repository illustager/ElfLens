<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ElfLens.Core.ViewModels"
             xmlns:cnv="using:ElfLens.Converters"
             xmlns:core="using:ElfLens.Core"
             x:Class="ElfLens.Views.DisassemblyPanelView"
             x:DataType="vm:DisassemblyPanelViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="4">
        <!-- Toolbar: static mode -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding IsDebugging, Converter={x:Static BoolConverters.Not}}">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="6,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
            <Button Content="Start Debugging" Command="{Binding StartDebuggingCommand}"
                    Padding="6,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
        </StackPanel>

        <!-- Toolbar: dynamic mode -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4"
                    IsVisible="{Binding IsDebugging}">
            <Button Content="Step Into" Command="{Binding StepIntoCommand}"
                    Padding="6,2" FontSize="11" />
            <Button Content="Step Over" Command="{Binding StepOverCommand}"
                    Padding="6,2" FontSize="11" />
            <Button Content="Continue" Command="{Binding ContinueCommand}"
                    Padding="6,2" FontSize="11" />
            <Button Content="Stop" Command="{Binding StopCommand}"
                    Padding="6,2" FontSize="11" />
            <Button Content="Restart" Command="{Binding RestartCommand}"
                    Padding="6,2" FontSize="11" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="{Binding FunctionCount}" FontSize="12"
                   Opacity="0.7" Margin="0,2,0,0" />

        <TextBlock Grid.Row="2" Text="Click a function to expand, click &lt;name&gt; to jump"
                   FontSize="10" Opacity="0.4" Margin="0,2,0,4" />

        <ScrollViewer Grid.Row="3" x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Functions}" x:CompileBindings="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FunctionItem">
                        <Border x:Name="fnBorder" Margin="0,0,0,2"
                                Background="{DynamicResource SystemAltMediumLowBrush}"
                                CornerRadius="3">
                            <StackPanel>
                                <Button Padding="6,3" Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding ToggleCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▸" FontSize="10" Width="12"
                                                   IsVisible="{Binding IsExpanded, Converter={x:Static BoolConverters.Not}}" />
                                        <TextBlock Text="▾" FontSize="10" Width="12"
                                                   IsVisible="{Binding IsExpanded}" />
                                        <TextBlock FontSize="11" FontFamily="Cascadia Code, Consolas, monospace">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}: {1} ({2} instructions)">
                                                    <Binding Path="Address" />
                                                    <Binding Path="Name" />
                                                    <Binding Path="Instructions.Count" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <ItemsControl ItemsSource="{Binding Instructions}"
                                              IsVisible="{Binding IsExpanded}"
                                              Margin="16,0,4,4" x:CompileBindings="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HighlightedLine">
                                            <Border Background="{Binding IsCurrent, Converter={x:Static cnv:HighlightConverters.CurrentBg}}"
                                                    CornerRadius="2" Margin="0,0,0,0">
                                                <ItemsControl ItemsSource="{Binding Tokens}" x:CompileBindings="False">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="core:Token">
                                                            <Button Padding="0" BorderThickness="0" Background="Transparent"
                                                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding NavigateTo}"
                                                                    IsEnabled="{Binding NavigateTo, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                                    Cursor="Hand" HorizontalContentAlignment="Left"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Text}"
                                                                           FontSize="12"
                                                                           FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                                                                           Foreground="{Binding Color, Converter={x:Static cnv:HighlightConverters.HexToBrush}}" />
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
