<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ElfLens.Core.ViewModels"
             xmlns:cnv="using:ElfLens.Converters"
             x:Class="ElfLens.Views.DisassemblyPanelView"
             x:DataType="vm:DisassemblyPanelViewModel">

    <Grid RowDefinitions="Auto,*" Margin="4">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="8,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
            <TextBlock Text="{Binding FunctionCount}" FontSize="12"
                       VerticalAlignment="Center" Opacity="0.7" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Lines}" x:CompileBindings="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:HighlightedLine">
                        <TextBlock Text="{Binding Text}"
                                   FontSize="12"
                                   FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                                   Margin="0,0,0,0"
                                   Foreground="{Binding Type, Converter={x:Static cnv:HighlightConverters.LineTypeBrush}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
