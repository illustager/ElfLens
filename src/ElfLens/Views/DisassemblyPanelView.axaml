<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ElfLens.Core.ViewModels"
             xmlns:cnv="using:ElfLens.Converters"
             xmlns:core="using:ElfLens.Core"
             x:Class="ElfLens.Views.DisassemblyPanelView"
             x:DataType="vm:DisassemblyPanelViewModel">

    <Grid RowDefinitions="Auto,Auto,*" Margin="4">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Content="Refresh" Command="{Binding RefreshCommand}"
                    Padding="6,2" FontSize="11"
                    IsEnabled="{Binding IsBusy, Converter={x:Static BoolConverters.Not}}" />
            <TextBlock Text="{Binding FunctionCount}" FontSize="12"
                       VerticalAlignment="Center" Opacity="0.7" />
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Click a function to expand, click &lt;name&gt; to jump"
                   FontSize="10" Opacity="0.4" Margin="0,4,0,6" />

        <ScrollViewer Grid.Row="2" x:Name="Scroller"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Functions}" x:CompileBindings="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FunctionItem">
                        <Border Margin="0,0,0,2"
                                Background="{DynamicResource SystemAltMediumLowBrush}"
                                CornerRadius="3">
                            <StackPanel>
                                <Button Padding="6,3" Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Command="{Binding ToggleCommand}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="▸" FontSize="10" Width="12"
                                                   IsVisible="{Binding IsExpanded, Converter={x:Static BoolConverters.Not}}" />
                                        <TextBlock Text="▾" FontSize="10" Width="12"
                                                   IsVisible="{Binding IsExpanded}" />
                                        <TextBlock FontSize="11" FontFamily="Cascadia Code, Consolas, monospace">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}: {1} ({2} instructions)">
                                                    <Binding Path="Address" />
                                                    <Binding Path="Name" />
                                                    <Binding Path="Instructions.Count" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>

                                <ItemsControl ItemsSource="{Binding Instructions}"
                                              IsVisible="{Binding IsExpanded}"
                                              Margin="16,0,4,4" x:CompileBindings="False">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:HighlightedLine">
                                            <Border BorderBrush="{Binding Converter={x:Static cnv:HighlightConverters.BreakpointBorder}}"
                                                    BorderThickness="3,0,0,0">
                                                <Border.ContextMenu>
                                                    <ContextMenu FontSize="11" FontFamily="Segoe UI, sans-serif">
                                                        <MenuItem Header="Set Breakpoint" Click="OnSetBreakpointClick" Padding="8,3" />
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                            <ItemsControl ItemsSource="{Binding Tokens}" x:CompileBindings="False"
                                                          Background="{Binding IsCurrent, Converter={x:Static cnv:HighlightConverters.CurrentBg}}"
                                                          PointerPressed="OnLineClicked">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="core:Token">
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontSize="12"
                                                                   FontFamily="Cascadia Code, Consolas, Menlo, monospace"
                                                                   Foreground="{Binding Color, Converter={x:Static cnv:HighlightConverters.HexToBrush}}"
                                                                   Cursor="{Binding NavigateTo, Converter={x:Static cnv:HighlightConverters.NavCursor}}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
